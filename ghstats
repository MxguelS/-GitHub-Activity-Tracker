#!/usr/bin/env bash
# ghstats — GitHub Activity Tracker en terminal (gum + gh + jq + toilet/lolcat)
set -euo pipefail

# ── Ayuda ─────────────────────────────────────────────────
show_help() {
  printf '\033[1;38;5;212m%s\033[0m\n' "ghstats — GitHub Activity Tracker"
  cat << EOF

Uso:
  ghstats [usuario] [opciones]

Opciones:
  --no-cache         Ignora el caché (5 min) y vuelve a consultar GitHub
  --repo <nombre>    Muestra los últimos 10 commits de un repo específico
  --help, -h         Muestra esta ayuda

Ejemplos:
  ghstats
  ghstats octocat    Muestra stats de octocat (o cualquier usuario de GitHub)
  ghstats --no-cache
  ghstats --repo mi-proyecto
EOF
  exit 0
}

# ── Preflight: dependencias + auth ───────────────────────
preflight() {
  local missing=()
  for cmd in gh jq gum; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if (( ${#missing[@]} > 0 )); then
    printf '\033[1;38;5;196m✗ Faltan dependencias: %s\033[0m\n' "${missing[*]}"
    echo "Instala con: sudo pacman -S github-cli jq gum"
    exit 1
  fi

  if ! gh auth status >/dev/null 2>&1; then
    printf '\033[1;38;5;196m✗ No has iniciado sesión en GitHub CLI\033[0m\n'
    if gum confirm "¿Iniciar sesión ahora?"; then
      gh auth login || { printf '\033[38;5;196m✗ Login cancelado/fallido.\033[0m\n'; exit 1; }
    else
      exit 1
    fi
  fi
}

# ── Parseo de argumentos ──────────────────────────────────
NO_CACHE=false
DIRECT_REPO=""
USER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  --help | -h) show_help ;;
  --no-cache) NO_CACHE=true; shift ;;
  --repo) DIRECT_REPO="$2"; shift 2 ;;
  *) USER="$1"; shift ;;
  esac
done

preflight

USER="${USER:-$(gh api user --jq '.login')}"
CACHE="/tmp/ghstats_cache_${USER}.json"
CACHE_TTL=300  # segundos

# ── Funciones de recolección de datos ────────────────────
cache_valid() {
  [[ "$NO_CACHE" == true ]] && return 1
  [[ -f "$CACHE" ]] && (( $(date +%s) - $(stat -c %Y "$CACHE") < CACHE_TTL ))
}

fetch_repos() {
  gh repo list "$USER" --limit 100 \
    --json name,stargazerCount,primaryLanguage,pushedAt,isPrivate \
    --jq '[.[] | select(.isPrivate==false)]'
}

fetch_languages() {
  local repos="$1"
  echo "$repos" | jq -r '.[].name' | while read -r repo; do
    local out
    out=$(gh api "repos/$USER/$repo/languages" 2>/dev/null)
    echo "$out" | jq -e . >/dev/null 2>&1 && echo "$out" || echo '{}'
  done | jq -s 'reduce .[] as $obj ({}; . * $obj)'
}

fetch_commits_30d() {
  local repos="$1"
  local since total=0
  since=$(date -d '30 days ago' +%Y-%m-%dT%H:%M:%SZ)
  while read -r repo; do
    local n
    n=$(gh api "repos/$USER/$repo/commits?since=$since&author=$USER" \
      --jq 'length' 2>/dev/null)
    [[ "$n" =~ ^[0-9]+$ ]] || n=0
    total=$((total + n))
  done < <(echo "$repos" | jq -r '.[].name')
  echo "$total"
}

fetch_contributions() {
  gh api graphql -f query='
    query($login: String!) {
      user(login: $login) {
        contributionsCollection {
          contributionCalendar { totalContributions }
        }
      }
    }' -f login="$USER" \
    --jq '.data.user.contributionsCollection.contributionCalendar.totalContributions'
}

fetch_issues() {
  local n
  n=$(gh search issues --author "$USER" --state open --json number --jq 'length' 2>/dev/null)
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  echo "$n"
}

fetch_all() {
  if cache_valid; then
    cat "$CACHE"
    return
  fi
  local repos languages commits contributions issues
  repos=$(fetch_repos)
  languages=$(fetch_languages "$repos")
  commits=$(fetch_commits_30d "$repos")
  contributions=$(fetch_contributions)
  issues=$(fetch_issues)

  jq -n \
    --argjson repos "$repos" \
    --argjson languages "$languages" \
    --argjson commits "$commits" \
    --argjson contributions "$contributions" \
    --argjson issues "$issues" \
    '{repos:$repos, languages:$languages, commits:$commits, contributions:$contributions, issues:$issues}' \
    | tee "$CACHE"
}

# ── Helpers de render ─────────────────────────────────────
bar() {
  local pct=$1 width=20
  local filled=$((pct * width / 100))
  local empty=$((width - filled))
  printf '%s%s' "$(printf '█%.0s' $(seq 1 $filled))" "$(printf '░%.0s' $(seq 1 $empty))"
}

# Header de sección con ANSI directo.
section_header() {
  printf '\n\033[1;38;5;99m%s\033[0m\n' "$1"
}

show_commits() {
  local repo="$1" limit="${2:-10}"
  if ! gh repo view "$USER/$repo" >/dev/null 2>&1; then
    printf '\033[1;38;5;196m✗ El repo '\''%s'\'' no existe o no es accesible para @%s\033[0m\n' "$repo" "$USER"
    return 1
  fi
  section_header "Últimos commits — $repo"
  gh api "repos/$USER/$repo/commits" --jq \
    ".[:$limit][] | \"\(.commit.author.date | split(\"T\")[0])\t\(.commit.message | split(\"\n\")[0])\"" \
    | gum table --separator $'\t' --print --widths 12,60
}

# ── Recolección con spinner ──────────────────────────────
DATA=$(gum spin --spinner dot --title "Consultando GitHub..." --show-output -- bash -c \
  "$(declare -f cache_valid fetch_repos fetch_languages fetch_commits_30d fetch_contributions fetch_issues fetch_all); \
   USER='$USER'; CACHE='$CACHE'; CACHE_TTL=$CACHE_TTL; fetch_all")

# ── Modo directo: --repo <nombre> ────────────────────────
if [[ -n "$DIRECT_REPO" ]]; then
  show_commits "$DIRECT_REPO" 10
  exit 0
fi

# ── Header con ASCII art ──────────────────────────────────
REPO_COUNT=$(echo "$DATA" | jq '.repos | length')
STARS=$(echo "$DATA" | jq '[.repos[].stargazerCount] | add // 0')
COMMITS=$(echo "$DATA" | jq -r '.commits')
CONTRIB=$(echo "$DATA" | jq -r '.contributions')
ISSUES=$(echo "$DATA" | jq -r '.issues')

echo
toilet -f pagga --gay "ghstats" 2>/dev/null | lolcat -s 42 2>/dev/null || \
  printf '\033[1;38;5;212m=== ghstats ===\033[0m\n'

gum style \
  --border rounded --border-foreground 99 \
  --padding "1 3" --margin "0 0 1 0" \
  --align center --width 50 \
  "$(gum style --bold --foreground 212 "@$USER")" \
  "" \
  "Repos: $REPO_COUNT   Stars: $STARS" \
  "Commits (30d): $COMMITS   Issues: $ISSUES" \
  "Contribuciones (año): $CONTRIB"

# ── Lenguajes (top 8, ≥ 1%) ───────────────────────────────
section_header "Lenguajes"
TOTAL_BYTES=$(echo "$DATA" | jq '.languages | add // 1')
echo "$DATA" | jq -r --argjson total "$TOTAL_BYTES" '
  .languages
  | to_entries
  | sort_by(-.value)
  | map(select((.value * 100 / $total) >= 1))
  | .[:8]
  | .[]
  | "\(.key)\t\(.value)"
' | while IFS=$'\t' read -r lang bytes; do
    [[ "$bytes" =~ ^[0-9]+$ ]] || continue
    pct=$((bytes * 100 / TOTAL_BYTES))
    printf "  %-15s %s %3d%%\n" "$lang" "$(bar $pct)" "$pct"
  done

# ── Tabla de repos interactiva (selecciona fila = elige repo) ──
section_header "Repositorios (Enter para elegir uno)"
TABLE_HEIGHT=$(( REPO_COUNT + 2 < 15 ? REPO_COUNT + 2 : 15 ))
SELECTED_ROW=$({
  echo "Nombre,Lenguaje,Stars,Último push"
  echo "$DATA" | jq -r '.repos[] | [.name, (.primaryLanguage.name // "N/A"), .stargazerCount, (.pushedAt | split("T")[0])] | @csv' | tr -d '"'
} | gum table --separator "," --widths 25,12,6,12 --height "$TABLE_HEIGHT")

SELECTED=$(echo "$SELECTED_ROW" | cut -d',' -f1)

# ── Acción sobre el repo elegido ──────────────────────────
if [[ -n "$SELECTED" ]]; then
  echo
  ACTION=$(gum choose --header "¿Qué quieres hacer con $SELECTED?" \
    "Abrir en navegador" "Ver últimos commits" "Salir")
  case "$ACTION" in
  "Abrir en navegador") gh repo view "$USER/$SELECTED" --web ;;
  "Ver últimos commits") show_commits "$SELECTED" 5 ;;
  *) exit 0 ;;
  esac
fi

# ── Footer ────────────────────────────────────────────────
echo
printf '\033[3;38;5;240m  Actualizado: %s\033[0m\n' "$(date '+%Y-%m-%d %H:%M')"
